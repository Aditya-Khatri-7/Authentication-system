# Server deployment environment
PORT=5000
NODE_ENV=production

# MongoDB connection details (Atlas cluster string or local uri fallback)
MONGODB_URI=mongodb://username:password@cluster.mongodb.net/database

# JWT Signing secrets (Use secure cryptographical random keys in production)
JWT_SECRET=use_a_very_long_secure_random_key_here
JWT_REFRESH_SECRET=use_another_very_long_secure_random_key_here
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Nodemailer SMTP Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_APP_PASSWORD=your_app_specific_password
EMAIL_FROM="Enterprise Authentication Service" <noreply@auth.local>

# CORS Whitelist Settings
FRONTEND_URL=http://localhost:5173
